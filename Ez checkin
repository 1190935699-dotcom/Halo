-- ==========================================
-- [Aimbot Variables]
-- ==========================================
local AimbotEnabled = false
local AimbotWallCheck = false
local AimbotKillCheck = false
local AimbotSmoothness = 5
local AimbotFOV = 200
local AimbotTargetPart = "Head"
local AimbotTeamCheck = false

local function CanSee(targetPart)
    if not AimbotWallCheck then return true end
    local origin = workspace.CurrentCamera.CFrame.Position
    local ray = Ray.new(origin, (targetPart.Position - origin))
    local hit = workspace:FindPartOnRay(ray, game.Players.LocalPlayer.Character)
    if hit and hit:IsDescendantOf(targetPart.Parent) then return true
    elseif not hit then return true end
    return false
end

local function IsTargetAlive(target)
    if not AimbotKillCheck then return true end
    local humanoid = target.Character and target.Character:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end

local function GetClosestTarget()
    local closest = nil
    local closestDist = AimbotFOV
    local center = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y / 2)
    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= game.Players.LocalPlayer then
            if AimbotTeamCheck and player.Team == game.Players.LocalPlayer.Team then continue end
            if not IsTargetAlive(player) then continue end
            local targetPart = player.Character and player.Character:FindFirstChild(AimbotTargetPart)
            if targetPart then
                local screenPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if dist < closestDist then
                        if AimbotWallCheck and not CanSee(targetPart) then continue end
                        closestDist = dist
                        closest = targetPart
                    end
                end
            end
        end
    end
    return closest
end

local function SmoothAim(targetPos)
    local currentCF = workspace.CurrentCamera.CFrame
    local targetCF = CFrame.new(currentCF.Position, targetPos)
    local newCF = currentCF:Lerp(targetCF, 1 / AimbotSmoothness)
    workspace.CurrentCamera.CFrame = newCF
end


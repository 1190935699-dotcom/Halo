-- ==========================================
-- [Main Render Loop]
-- ==========================================
game:GetService("RunService").RenderStepped:Connect(function()
    FOV_Circle.Position = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y / 2)
    
    if AimbotEnabled then
        local target = GetClosestTarget()
        if target then SmoothAim(target.Position) end
    end
    
    SpeedGlitch()
    Launch()
    
    if NoclipEnabled then pcall(Noclip) end
    if TPWalkEnabled then pcall(TPWalk) end
    if InvisibleEnabled then pcall(ToggleInvisible) end
    if GodModeEnabled then pcall(ToggleGodMode) end
    if HitboxEnabled then pcall(ToggleHitbox) else pcall(ToggleHitbox) end
    
    if FullBrightEnabled then
        game.Lighting.Brightness = 2
        game.Lighting.ClockTime = 14
        game.Lighting.FogEnd = 100000
    end
    
    if NPCAimEnabled then
        local target, dist = nil, FOV_Circle.Radius
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") and v:FindFirstChild("Humanoid") and not game.Players:GetPlayerFromCharacter(v) then
                local head = v:FindFirstChild("Head")
                if head then
                    local screenPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(head.Position)
                    if onScreen then
                        local mag = (Vector2.new(screenPos.X, screenPos.Y) - FOV_Circle.Position).Magnitude
                        if mag < dist then dist, target = mag, head end
                    end
                end
            end
        end
        if target then workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target.Position) end
    end
    
    pcall(function()
        if game.Players.LocalPlayer.Character then
            game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = WalkSpeedValue
            game.Players.LocalPlayer.Character.Humanoid.JumpPower = JumpPowerValue
        end
        
        if ESP_Enabled then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Model") and v:FindFirstChild("Humanoid") and not v:FindFirstChild("G666_ESP") then
                    local hl = Instance.new("Highlight", v); hl.Name = "G666_ESP"; hl.FillColor = Color3.fromRGB(255, 0, 0)
                end
            end
        end
        
        if Object_ESP_Enabled and SelectedObject ~= "None" then
            for _, v in pairs(workspace:GetDescendants()) do
                if v.Name:lower():find(SelectedObject:lower()) and not v:FindFirstChild("Obj_HL") then
                    local hl = Instance.new("Highlight", v); hl.Name = "Obj_HL"; hl.FillColor = Color3.fromRGB(255, 255, 0)
                end
            end
        end
    end)
end)

